// api/checkout/success.js (Next.js API Route)

import { prisma } from '../../lib/prisma';
import { generateLicenseKey } from '../../lib/license';

export default async function handler(req, res) {
    const { sessionId, productId, buyerId } = req.body;
    
    // 1. Verificar pago con Stripe
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    
    if (session.payment_status !== 'paid') {
        return res.status(400).json({ error: 'Pago no completado' });
    }
    
    // 2. Crear compra en la base de datos
    const licenseKey = generateLicenseKey(); // Genera key única
    
    const purchase = await prisma.purchase.create({
        data: {
            buyerId,
            productId,
            amount: session.amount_total / 100,
            status: 'COMPLETED',
            licenseKey,
            transactionId: session.id
        }
    });
    
    // 3. Actualizar ventas del producto
    await prisma.product.update({
        where: { id: productId },
        data: { sales: { increment: 1 } }
    });
    
    // 4. Enviar email con la licencia
    await sendLicenseEmail({
        to: session.customer_email,
        productName: purchase.product.name,
        licenseKey,
        downloadUrl: `https://tudominio.com/download/${purchase.id}`
    });
    
    // 5. Pagar al vendedor (85% del precio)
    const seller = await prisma.product.findUnique({
        where: { id: productId },
        select: { seller: true, price: true }
    });
    
    const commission = seller.price * 0.15; // 15% para ti
    const sellerEarnings = seller.price - commission;
    
    await prisma.user.update({
        where: { id: seller.seller.id },
        data: { balance: { increment: sellerEarnings } }
    });
    
    res.json({ 
        success: true, 
        licenseKey,
        downloadUrl: `/download/${purchase.id}`
    });
}
